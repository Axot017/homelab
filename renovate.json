{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes"
  ],
  "ignorePaths": [
    "k8s/clusters/homelab/flux-system/gotk-components.yaml"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^k8s/.+\\.ya?ml$"
      ],
      "matchStrings": [
        "repository:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*tag:\\s*\\\"?(?<currentValue>[^\\\"\\s]+)\\\"?"
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchManagers": [
        "kubernetes",
        "custom.regex"
      ],
      "groupName": "docker image updates",
      "groupSlug": "docker-image-updates"
    }
  ]
}
