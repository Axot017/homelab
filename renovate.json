{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "kubernetes",
    "mise"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/^k8s\\/.*\\.ya?ml$/"
    ]
  },
  "ignorePaths": [
    "k8s/clusters/homelab/flux-system/gotk-components.yaml"
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchManagers": [
        "kubernetes"
      ],
      "groupName": "docker image updates",
      "groupSlug": "docker-image-updates"
    }
  ]
}
